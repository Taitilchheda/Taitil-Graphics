# Auth — JWT signing secret. Generate with: `openssl rand -hex 32`
JWT_SECRET=replace-with-a-long-random-string

# Database (Prisma). Free MongoDB Atlas M0 cluster recommended for now.
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/taitil
# Run `npx prisma db push` after creating the cluster to provision collections.
DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/taitil?retryWrites=true&w=majority

# OTP service (deprecated — replaced by Firebase Auth email-link sign-in).
# Leave unset. The dead-upstream at OTP_SERVICE_URL has been intermittent
# for months; Firebase Auth handles passwordless sign-in now.
# OTP_SERVICE_URL=https://otp-service-beta.vercel.app
# OTP_DEV_FALLBACK=true

# Google Maps (optional, used by location-aware features)
GOOGLE_MAPS_API_KEY=

# WhatsApp business number used to build wa.me links
WHATSAPP_NUMBER=917666247666

# GST invoice export / branding
SELLER_GSTIN=
SELLER_STATE=
GST_RATE_PERCENT=18

SELLER_NAME=Taitil Graphics
SELLER_TAGLINE=Studio-grade printing & celebration decor
SELLER_ADDRESS=
SELLER_CITY_STATE=
SELLER_CONTACT=
SELLER_LOGO_URL=/logo.svg

# Optional: CSRF protection (default on if unset). Set to "true" to disable
# (e.g. when running trusted server-to-server jobs). Never disable in production.
CSRF_ENABLED=

# Optional: Upstash Redis for distributed rate limiting. If unset, rate
# limiting falls back to a per-process in-memory map (caveat: cold starts
# reset counters). Recommended once traffic picks up.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------- Firebase Auth (email-link sign-in) ----------
# Web SDK config from Firebase Console → Project Settings → Your apps
# → Web app. These are PUBLIC — they ship to the browser. The secret
# (service account key) is set separately below.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional, only if Analytics is enabled:
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Server-side Firebase Admin SDK credential. Download from Firebase
# Console → Project Settings → Service Accounts → Generate New
# Private Key, then base64-encode the JSON content so the multi-line
# secret fits on one env-var line.
#   PowerShell: [Convert]::ToBase64String([System.IO.File]::ReadAllBytes('serviceAccount.json'))
#   Linux/macOS: base64 -w 0 serviceAccount.json
# Set this in Vercel → Settings → Environment Variables for
# Production, Preview, and Development.
FIREBASE_SERVICE_ACCOUNT_JSON_B64=