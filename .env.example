# Auth — JWT signing secret. Generate with: `openssl rand -hex 32`
JWT_SECRET=replace-with-a-long-random-string

# Database (Prisma). Free MongoDB Atlas M0 cluster recommended for now.
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/taitil
# Run `npx prisma db push` after creating the cluster to provision collections.
DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/taitil?retryWrites=true&w=majority

# Email-OTP service. We proxy /api/auth/otp/send and
# /api/auth/otp/verify to this URL — the upstream
# (github.com/sauravhathi/otp-service) is what actually sends the
# email. Set OTP_SERVICE_URL in Vercel env vars to your own
# deployment if you fork it. The upstream stores OTPs in its own
# MongoDB and serves them back via /api/otp/verify; we do not need
# to store anything in our database.
OTP_SERVICE_URL=https://otp-service-beta.vercel.app

# Google Maps (optional, used by location-aware features)
GOOGLE_MAPS_API_KEY=

# WhatsApp business number used to build wa.me links
WHATSAPP_NUMBER=917666247666

# GST invoice export / branding
SELLER_GSTIN=
SELLER_STATE=
GST_RATE_PERCENT=18

SELLER_NAME=Taitil Graphics
SELLER_TAGLINE=Studio-grade printing & celebration decor
SELLER_ADDRESS=
SELLER_CITY_STATE=
SELLER_CONTACT=
SELLER_LOGO_URL=/logo.svg

# Optional: CSRF protection (default on if unset). Set to "true" to disable
# (e.g. when running trusted server-to-server jobs). Never disable in production.
CSRF_ENABLED=

# Optional: Upstash Redis for distributed rate limiting. If unset, rate
# limiting falls back to a per-process in-memory map (caveat: cold starts
# reset counters). Recommended once traffic picks up.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=