// Taitil Graphics — MongoDB schema (replaces PostgreSQL).
//
// We use MongoDB Atlas (M0 free tier) until the business scales; the goal
// is to migrate back to PostgreSQL + a paid host once real orders start
// coming in. Until then, ordering happens entirely via WhatsApp / phone
// call, so the schema only needs to support catalog, leads, basic auth,
// chat, reviews, and admin.
//
// IMPORTANT: Prisma's MongoDB connector requires `@map("_id")` on every
// primary key (Mongo's _id is required) and doesn't support native enums
// or SQL-style transactions. We model enums as constrained strings; for
// multi-document writes, prefer `prisma.$transaction([])` (array form)
// which is supported on replica sets and falls back gracefully on the
// free-tier single-node cluster.

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  // Vercel runs on Linux (AWS Lambda). Without `binaryTargets`, Prisma
  // generates a binary for the local dev platform only and the client
  // fails at runtime in production.
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

// ---------- Enum-equivalent string constants (used by Zod validators) ----------
// Role: "CUSTOMER" | "ADMIN"
// OrderStatus: "PENDING" | "PAID" | "SHIPPED" | "DELIVERED" | "CANCELLED"
// PaymentStatus: "PENDING" | "PAID" | "FAILED" | "REFUNDED"
// ProductType: "PHYSICAL" | "SERVICE"
// AnalyticsEventType: "CLICK" | "VIEW" | "INQUIRY" | "CART" | "SALE" | "INVENTORY" | "PRODUCT_ADDED"

model User {
  id           String   @id @default(cuid()) @map("_id")
  email        String   @unique
  password     String?
  name         String?
  role         String   @default("CUSTOMER")
  phone        String?
  address      String?
  isBusiness   Boolean  @default(false)
  businessName String?
  gstNumber    String?
  // Epoch (ms) of the latest session invalidation. Any JWT issued at
  // or before this timestamp is rejected. Bump on logout, password
  // change, or admin force-revoke.
  sessionInvalidatedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  addresses   Address[]
  carts       Cart[]
  orders      Order[]
  reviews     Review[]
  adminAudits AdminAudit[]
}

model Category {
  id          String   @id @map("_id")
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subcategories Subcategory[]
  products      Product[]
}

model Subcategory {
  id          String   @id @map("_id")
  name        String
  description String?
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]
}

model Product {
  id                String   @id @default(cuid()) @map("_id")
  name              String
  description       String
  categoryId        String
  subcategoryId     String?
  image             String
  images            Json?
  features          Json?
  badges            Json?
  type              String   @default("PHYSICAL")
  variants          Json?
  media             Json?
  seoTitle          String?
  seoDescription    String?
  canonicalUrl      String?
  priceCents        Int      @default(0)
  weightGrams       Int?
  lengthCm          Int?
  widthCm           Int?
  heightCm          Int?
  hsnCode           String?
  fragile           Boolean  @default(false)
  listingPriceCents Int      @default(0)
  discountPercent   Int      @default(0)
  sku               String?  @unique
  stock             Int?
  reserved          Int      @default(0)
  reorderLevel      Int?     @default(5)
  lowStockThreshold Int?     @default(5)
  isNew             Boolean  @default(true)
  isRecommended     Boolean? @default(true)
  isHotSeller       Boolean? @default(false)
  whatsappMsg       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subcategory Subcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  carts       CartItem[]
  orderItems  OrderItem[]
  reviews     Review[]
  leads       Lead[]

  @@index([categoryId])
  @@index([subcategoryId])
  @@index([categoryId, subcategoryId])
  @@index([isRecommended])
  @@index([isHotSeller])
  @@index([createdAt])
}

model Address {
  id           String   @id @default(cuid()) @map("_id")
  userId       String
  fullName     String
  line1        String
  line2        String?
  city         String
  state        String
  postal       String
  country      String   @default("IN")
  phone        String?
  address      String?
  isBusiness   Boolean  @default(false)
  businessName String?
  gstNumber    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]
}

model Cart {
  id        String   @id @default(cuid()) @map("_id")
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]
}

model CartItem {
  id        String @id @default(cuid()) @map("_id")
  cartId    String
  productId String
  quantity  Int    @default(1)

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// Order is now an enquiry/quote record, not a paid transaction. Created
// from the "request a call back" flow. Payment/shipping fields are kept
// for forward-compat with the eventual Postgres migration, but always
// null on this deployment.
model Order {
  id              String   @id @default(cuid()) @map("_id")
  userId          String
  status          String   @default("PENDING")
  paymentStatus   String   @default("PENDING")
  currency        String   @default("INR")
  subtotalCents   Int      @default(0)
  taxCents        Int      @default(0)
  totalCents      Int      @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     OrderItem[]
  addressId String?
  address   Address?   @relation(fields: [addressId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model OrderItem {
  id         String @id @default(cuid()) @map("_id")
  orderId    String
  productId  String
  quantity   Int    @default(1)
  priceCents Int    @default(0)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model AnalyticsEvent {
  id            String   @id @default(cuid()) @map("_id")
  type          String
  productId     String?
  categoryId    String?
  subcategoryId String?
  label         String?
  quantity      Int?
  value         Int?
  meta          Json?
  createdAt     DateTime @default(now())

  @@index([productId])
  @@index([type])
}

model Review {
  id         String    @id @default(cuid()) @map("_id")
  productId  String
  userId     String
  rating     Int
  title      String?
  body       String?
  verified   Boolean   @default(false)
  status     String    @default("PENDING")
  response   String?
  respondedAt DateTime?
  createdAt  DateTime  @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
}

// Lead = WhatsApp/call enquiry. Replaces the old "checkout creates an
// order" flow: customers fill the form, we get a row, we call them back.
model Lead {
  id          String   @id @default(cuid()) @map("_id")
  productId   String?
  name        String
  email       String?
  phone       String
  subject     String?
  message     String?
  requirement String?
  budgetRange String?
  timeline    String?
  status      String   @default("NEW")
  source      String?
  assignedTo  String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([status])
}

model OtpCode {
  id         String    @id @default(cuid()) @map("_id")
  phone      String
  purpose    String
  codeHash   String
  expiresAt  DateTime
  attempts   Int       @default(0)
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([phone, purpose])
  @@index([expiresAt])
}

model AdminAudit {
  id        String   @id @default(cuid()) @map("_id")
  adminId   String
  action    String
  target    String?
  meta      Json?
  createdAt DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

// ChatSession + ChatMessage replace the file-backed store at /tmp.
// Sessions are per-visitor (user.id or guest cookie); messages are
// referenced by session id so reads stay cheap.
model ChatSession {
  id        String   @id @default(cuid()) @map("_id")
  // user:<userId> for authenticated users, guest:<uuid> otherwise.
  conversationId String @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ChatMessage[]
}

model ChatMessage {
  id        String   @id @default(cuid()) @map("_id")
  sessionId String
  message   String
  sender    String   // "user" | "support"
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}